# H2S Smart Communities - Environment Variables Example
# Copy this file to .env and fill in your actual keys

# Google Gen AI (Gemini)
# Get your key here: https://makersuite.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# Groq (optional, if using Groq)
# Get your key here: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Server port (optional)
PORT=3000
